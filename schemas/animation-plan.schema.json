{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.local/ai-delegate-avatar/animation-plan.v1.schema.json",
  "title": "Animation Plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "title", "durationMs", "safetyMode", "targetRig", "tracks"],
  "properties": {
    "schemaVersion": {"const": "animation-plan.v1"},
    "title": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "durationMs": {"type": "integer", "minimum": 1000, "maximum": 300000},
    "safetyMode": {
      "type": "string",
      "enum": ["offline_review_only", "disclosed_ai_delegate", "local_operator_approved"]
    },
    "targetRig": {"type": "string", "minLength": 1},
    "plannerNotes": {"type": "string"},
    "tracks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["states", "gestures"],
      "properties": {
        "states": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/stateEvent"}
        },
        "gestures": {
          "type": "array",
          "items": {"$ref": "#/$defs/gestureEvent"}
        },
        "speech": {
          "type": "array",
          "items": {"$ref": "#/$defs/speechEvent"}
        },
        "overlays": {
          "type": "array",
          "items": {"$ref": "#/$defs/overlayEvent"}
        }
      }
    }
  },
  "$defs": {
    "eventId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "stateName": {
      "type": "string",
      "enum": ["idle", "listening", "thinking", "agreeing", "uncertain", "speaking", "summarising", "deferring", "boundary", "reset_neutral"]
    },
    "gestureName": {
      "type": "string",
      "enum": ["blink", "slow_blink", "micro_nod", "small_nod", "head_tilt_left", "head_tilt_right", "brow_raise", "brow_furrow", "glance_aside", "glance_down", "half_smile", "caveat_expression", "defer_to_human", "reset_neutral"]
    },
    "speechAct": {
      "type": "string",
      "enum": ["acknowledge_question", "factual_answer", "qualified_answer", "summary", "clarifying_question", "deferral", "boundary_refusal"]
    },
    "affect": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "warmth": {"type": "number", "minimum": 0, "maximum": 1},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "uncertainty": {"type": "number", "minimum": 0, "maximum": 1},
        "energy": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "stateEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "startMs", "durationMs", "state"],
      "properties": {
        "id": {"$ref": "#/$defs/eventId"},
        "type": {"const": "state"},
        "startMs": {"type": "integer", "minimum": 0},
        "durationMs": {"type": "integer", "minimum": 1},
        "state": {"$ref": "#/$defs/stateName"},
        "intensity": {"type": "number", "minimum": 0, "maximum": 1},
        "attention": {
          "type": "string",
          "enum": ["camera", "current_speaker", "down_left", "down_right", "aside_left", "aside_right", "none"]
        },
        "affect": {"$ref": "#/$defs/affect"},
        "reason": {"type": "string"}
      }
    },
    "gestureEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "startMs", "durationMs", "gesture"],
      "properties": {
        "id": {"$ref": "#/$defs/eventId"},
        "type": {"const": "gesture"},
        "startMs": {"type": "integer", "minimum": 0},
        "durationMs": {"type": "integer", "minimum": 1},
        "gesture": {"$ref": "#/$defs/gestureName"},
        "intensity": {"type": "number", "minimum": 0, "maximum": 1},
        "reason": {"type": "string"}
      }
    },
    "speechEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "startMs", "text", "speechAct"],
      "properties": {
        "id": {"$ref": "#/$defs/eventId"},
        "type": {"const": "speech"},
        "startMs": {"type": "integer", "minimum": 0},
        "durationMs": {"type": "integer", "minimum": 1},
        "text": {"type": "string", "minLength": 1},
        "speechAct": {"$ref": "#/$defs/speechAct"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "emphasis": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["text", "gesture"],
            "properties": {
              "text": {"type": "string", "minLength": 1},
              "gesture": {"$ref": "#/$defs/gestureName"}
            }
          }
        },
        "reason": {"type": "string"}
      }
    },
    "overlayEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "startMs", "durationMs", "text"],
      "properties": {
        "id": {"$ref": "#/$defs/eventId"},
        "type": {"const": "overlay"},
        "startMs": {"type": "integer", "minimum": 0},
        "durationMs": {"type": "integer", "minimum": 1},
        "text": {"type": "string", "minLength": 1},
        "position": {"type": "string", "enum": ["lower_third", "top_left", "top_right", "bottom_left", "bottom_right"]},
        "reason": {"type": "string"}
      }
    }
  }
}
