{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.local/ai-delegate-avatar/rig-profile.v1.schema.json",
  "title": "Rig Profile v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "rigId", "renderer", "parameters", "hotkeys"],
  "properties": {
    "schemaVersion": {"const": "rig-profile.v1"},
    "rigId": {"type": "string", "minLength": 1},
    "renderer": {"const": "vtube_studio"},
    "model": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "expectedModelId": {"type": "string", "minLength": 1},
        "expectedModelName": {"type": "string", "minLength": 1},
        "assetVersion": {"type": "string", "minLength": 1}
      },
      "anyOf": [
        {
          "required": ["expectedModelId"],
          "properties": {"expectedModelId": {"type": "string", "minLength": 1}}
        },
        {
          "required": ["expectedModelName"],
          "properties": {"expectedModelName": {"type": "string", "minLength": 1}}
        }
      ]
    },
    "parameters": {
      "type": "object",
      "propertyNames": {"pattern": "^[a-z][a-z0-9]*(\\.[a-z0-9]+)*$"},
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["vtsInputParameter", "min", "max", "neutral"],
        "properties": {
          "vtsInputParameter": {"type": "string", "minLength": 1},
          "min": {"type": "number"},
          "max": {"type": "number"},
          "neutral": {"type": "number"},
          "weight": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "hotkeys": {
      "type": "object",
      "propertyNames": {"pattern": "^[a-z][a-z0-9_]*$"},
      "additionalProperties": {"type": "string", "minLength": 1}
    }
  }
}
