{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.local/ai-delegate-avatar/scenario-corpus.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "scenarios"],
  "properties": {
    "schemaVersion": { "const": "animation-plan-corpus.v1" },
    "scenarios": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/scenario" } }
  },
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "state": {
      "type": "string",
      "enum": ["idle", "listening", "thinking", "agreeing", "uncertain", "speaking", "summarising", "deferring", "boundary", "reset_neutral"]
    },
    "speechAct": {
      "type": "string",
      "enum": ["acknowledge_question", "factual_answer", "qualified_answer", "summary", "clarifying_question", "deferral", "boundary_refusal"]
    },
    "stateArray": { "type": "array", "items": { "$ref": "#/$defs/state" } },
    "speechActArray": { "type": "array", "items": { "$ref": "#/$defs/speechAct" } },
    "expectations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requiredStates": { "$ref": "#/$defs/stateArray" },
        "forbiddenStates": { "$ref": "#/$defs/stateArray" },
        "requiredSpeechActs": { "$ref": "#/$defs/speechActArray" },
        "forbiddenSpeechActs": { "$ref": "#/$defs/speechActArray" },
        "minimumRequiredStateDurationMs": { "type": "integer", "minimum": 1 },
        "requiredStateOrder": { "$ref": "#/$defs/stateArray" },
        "requiredSpeechActStates": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["speechAct", "state"],
            "properties": {
              "speechAct": { "$ref": "#/$defs/speechAct" },
              "state": { "$ref": "#/$defs/state" }
            }
          }
        },
        "maxNonBlinkGestures": { "type": "integer", "minimum": 0 },
        "fullDurationDisclosure": { "type": "boolean" },
        "terminalNeutralReset": { "type": "boolean" }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "brief", "targetRig", "durationMs", "expectations"],
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyString" },
        "title": { "$ref": "#/$defs/nonEmptyString" },
        "brief": { "$ref": "#/$defs/nonEmptyString" },
        "targetRig": { "$ref": "#/$defs/nonEmptyString" },
        "durationMs": {
          "type": "object",
          "additionalProperties": false,
          "required": ["min", "max"],
          "properties": {
            "min": { "type": "integer", "minimum": 1 },
            "max": { "type": "integer", "minimum": 1 }
          }
        },
        "expectations": { "$ref": "#/$defs/expectations" }
      }
    }
  }
}
